rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -- Helpers ----------------------------------------------
    function isLoggedIn()  { return request.auth != null; }
    function uid()         { return request.auth.uid; }
    function isOwner(id)   { return uid() == id; }

    function isAdmin() {
      return isLoggedIn() &&
        exists(/databases/$(database)/documents/users/$(uid())) &&
        get(/databases/$(database)/documents/users/$(uid())).data.role == 'admin';
    }

    function isAdminByEmail() {
      return isLoggedIn() && (
        request.auth.token.email == 'admin@sewaone.in' ||
        request.auth.token.email_verified == true &&
        exists(/databases/$(database)/documents/users/$(uid())) &&
        get(/databases/$(database)/documents/users/$(uid())).data.role == 'admin'
      );
    }

    function isAgent() {
      return isLoggedIn() &&
        exists(/databases/$(database)/documents/agents/$(uid()));
    }

    function isAdminOrAgent() {
      return isAdmin() || isAgent();
    }

    // ========================================================
    // USERS
    // ========================================================
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdminOrAgent();
      allow create: if request.auth != null;
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // User-specific notifications subcollection
    match /users/{userId}/notifications/{notiId} {
      allow read:   if isOwner(userId) || isAdmin();
      allow create: if isAdmin() || isAgent();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isOwner(userId) || isAdmin();
    }

    // ========================================================
    // AGENTS
    // ========================================================
    match /agents/{agentId} {
      allow read:   if isAdminOrAgent();
      allow write:  if isAdmin();
    }

    match /agent_permissions/{agentId} {
      allow read:   if isAdminOrAgent();
      allow write:  if isAdmin();
    }

    // ========================================================
    // GOVERNMENT JOBS
    // ========================================================
    match /job_wizard_configs/{jobId} {
      allow read:   if true;
      allow write:  if isAdmin();
    }

    match /gov_jobs/{jobId} {
      allow read:   if true;
      allow write:  if isAdmin();
    }

    // ========================================================
    // ALL SERVICES
    // ========================================================
    match /all_services/{serviceId} {
      allow read:   if true;
      allow write:  if isAdmin();
    }

    // ✅ NEW — Service wizard configs
    match /service_wizard_configs/{serviceId} {
      allow read:   if true;
      allow write:  if isAdmin();
    }

    // ========================================================
    // JOB APPLICATIONS
    // ========================================================
    match /applications/{appId} {
      allow read: if isLoggedIn() && (
        resource.data.userId == uid() || isAdminOrAgent()
      );
      allow create: if isLoggedIn() && request.resource.data.userId == uid();
      allow update: if isAdmin() ||
        (isAgent() && resource.data.assignedTo == uid());
      allow delete: if isAdmin();

      match /messages/{msgId} {
        allow read:  if isLoggedIn() && (
          get(/databases/$(database)/documents/applications/$(appId)).data.userId == uid() ||
          isAdminOrAgent()
        );
        allow create: if isLoggedIn();
        allow update, delete: if isAdmin();
      }
    }

    // ========================================================
    // SERVICE APPLICATIONS
    // ========================================================
    match /service_applications/{appId} {
      allow read: if isLoggedIn() && (
        resource.data.userId == uid() || isAdminOrAgent()
      );
      allow create: if isLoggedIn() && request.resource.data.userId == uid();
      allow update: if isAdmin() ||
        (isAgent() && resource.data.assignedTo == uid());
      allow delete: if isAdmin();

      match /messages/{msgId} {
        allow read:  if isLoggedIn() && (
          get(/databases/$(database)/documents/service_applications/$(appId)).data.userId == uid() ||
          isAdminOrAgent()
        );
        allow create: if isLoggedIn();
        allow update, delete: if isAdmin();
      }
    }

    // ========================================================
    // WALLET REQUESTS
    // ========================================================
    match /wallet_requests/{reqId} {
      allow read: if isLoggedIn() && (
        resource.data.userId == uid() || isAdmin()
      );
      allow create: if isLoggedIn() && request.resource.data.userId == uid();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ========================================================
    // TRANSACTIONS
    // ========================================================
    match /transactions/{txId} {
      allow read: if isLoggedIn() && (
        resource.data.userId == uid() || isAdmin()
      );
      allow create: if isLoggedIn() && request.resource.data.userId == uid();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ========================================================
    // NOTIFICATIONS (Bell icon)
    // ========================================================
    match /notifications/{notiId} {
      allow read:   if isLoggedIn();
      allow create: if isAdmin();
      allow update: if isLoggedIn() && (
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['readBy', 'isRead', 'readAt']) || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ========================================================
    // VOUCHERS / COUPONS
    // ========================================================
    match /vouchers/{voucherId} {
      allow read:   if isLoggedIn();
      allow write:  if isAdmin();
    }

    match /voucher_usage_requests/{reqId} {
      allow read:   if isLoggedIn() && (
        resource.data.userId == uid() || isAdmin()
      );
      allow create: if isLoggedIn() && request.resource.data.userId == uid();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ========================================================
    // BANNERS
    // ========================================================
    match /banners/{bannerId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ========================================================
    // UPDATES / TICKER
    // ========================================================
    match /updates/{updateId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ========================================================
    // FAQs & HELP
    // ========================================================
    match /faqs/{faqId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    match /help_articles/{articleId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ========================================================
    // GRIEVANCES
    // ========================================================
    match /grievances/{gId} {
      allow read: if isLoggedIn() && (
        resource.data.userId == uid() || isAdmin()
      );
      allow create: if isLoggedIn() && request.resource.data.userId == uid();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ========================================================
    // MASTER DATA
    // ========================================================
    match /master_eligibility/{docId} {
      allow read:  if isLoggedIn();
      allow write: if isAdmin();
    }

    match /master_documents/{docId} {
      allow read:  if isLoggedIn();
      allow write: if isAdmin();
    }

    // ========================================================
    // APP CONFIG
    // ========================================================
    match /app_config/{configId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ========================================================
    // ANALYTICS EVENTS
    // ========================================================
    match /analytics_events/{eventId} {
      allow create: if isLoggedIn() && request.resource.data.userId == uid();
      allow read:   if isAdmin();
      allow update, delete: if false;
    }

    // ========================================================
    // LOGS
    // ========================================================
    match /admin_logs/{logId} {
      allow read:   if isAdmin();
      allow write:  if false;
    }

    match /audit_logs/{logId} {
      allow read:   if isAdmin();
      allow create: if isLoggedIn();
      allow update: if false;
      allow delete: if false;
    }

    match /notification_logs/{logId} {
      allow read:   if isAdmin();
      allow write:  if isAdmin();
    }

    // ========================================================
    // MEMBERSHIP
    // ========================================================
    match /user_memberships/{userId} {
      allow read:   if isLoggedIn() && (isOwner(userId) || isAdmin());
      // SEC-01 Fix: create only by owner OR admin — not any logged-in user
      allow create: if isLoggedIn() && (isOwner(userId) || isAdmin());
      allow update: if isLoggedIn() && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();
    }

    match /user_memberships/{userId}/monthly_usage/{month} {
      allow read:  if isLoggedIn() && (isOwner(userId) || isAdmin());
      allow write: if isLoggedIn() && (isOwner(userId) || isAdmin());
    }

    match /user_memberships/{userId}/history/{historyId} {
      allow read:   if isLoggedIn() && (isOwner(userId) || isAdmin());
      allow create: if isLoggedIn() && (isOwner(userId) || isAdmin());
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /membership_overrides/{userId} {
      allow read:  if isLoggedIn() && (isOwner(userId) || isAdmin());
      allow write: if isAdmin();
    }

  }
}
